# Copy to backend/.env and fill in the secrets. LF endings + no BOM.

# --- Database / broker ---
DATABASE_URL=sqlite+aiosqlite:///./batchchef.db
REDIS_URL=redis://localhost:6379/0

# --- AI (Gemini primaire, Claude optionnel) ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite-preview
# Throttle: 0 on paid tier, ~6 on free (10 RPM)
GEMINI_MIN_INTERVAL_S=1.0

# Optional Anthropic fallback (not used in V3 by default)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MIN_INTERVAL_S=12.5

AI_PROVIDER=gemini

# --- Scraping Québec ---
MAXI_STORE_ID=7234
MAXI_POSTAL_CODE=G1M 3E5
COSTCO_ENABLED=true
COSTCO_POSTAL_CODE=G2J 1E3
COSTCO_WAREHOUSE_NAME_HINT=Quebec
# Costco REQUIRES headful (Akamai blocks headless); set true for Maxi-only runs
PLAYWRIGHT_HEADLESS=false
SCRAPE_CONCURRENCY=5
SCRAPE_RETRIES=3
PRICE_STALE_DAYS=14

# --- API / CORS ---
HOST=0.0.0.0
UPLOADS_DIR=../uploads
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- Auth (disabled in V3 frontend, but JWT secret still required) ---
SECRET_KEY=change-me-in-prod
ADMIN_EMAIL=admin@batchchef.com
ADMIN_PASSWORD=
