# Copy to frontend/.env.local for local dev. Next.js auto-loads it.
# .env.local is .gitignored so you can keep machine-specific values here.

# FastAPI backend URL — must match the port the API listens on.
# Supervisor / start.ps1 launches uvicorn on :8001.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8001
